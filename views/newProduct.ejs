<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel = "stylesheet" href = "/styles/general.css">
    <link rel = "stylesheet" href = "/styles/productsStyles.css">
    <link rel = "stylesheet" href = "/styles/newProductStyles.css">
    <link rel="icon" type="image/png" href="/images/mercadona.png">
    <title>Productos | Mercadona</title>
</head>
<body>
    <div class="container">
        <%- include ("partials/navbar") %>
        <main class="homeNewProduct">
            <div class="form-card newProduct-card">
                <span class = "title">Nuevo producto</span>
                <p class="newProduct-subtitle">Rellena la ficha, en un momento estará en el catálogo.</p>

                <form method="POST" action="/productos/nuevo" class="newProductForm">
                    <div class="newProduct-grid">
                        <div class="field">
                            <label for="product_name">Nombre</label>
                            <input id="product_name" name="product_name" placeholder="Manzana...">
                        </div>

                        <div class="field">
                            <label for="product_price">Precio</label>
                            <input id="product_price" name="product_price" placeholder="2.95 ...">
                        </div>

                        <div class="field">
                            <label for="product_category">Categoría</label>
                            <div class="select-wrap">
                                <select id="product_category" name="product_category">
                                    <option value="">Selecciona una categoría</option>
                                    <% categories.forEach(category => { %>
                                        <option value="<%= category %>"><%= category %></option>
                                    <% }) %>
                                </select>
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                    <path d="M6 9l6 6 6-6"/>
                                </svg>
                            </div>
                        </div>

                        <div class="field">
                            <label for="product_photo">Foto</label>
                            <input id="product_photo" name="product_photo" placeholder="https://google.com/images ...">
                        </div>

                        <div class ="field">
                            <label for ="master_password">Contraseña...</label>
                            <input id="master_password" name="master_password">
                        </div>
                    </div>

                    <div class="photo-preview" id="photoPreview">
                        <img id="photoPreviewImg" alt="Vista previa del producto">
                        <span class="photo-preview-placeholder">La foto aparecerá aquí</span>
                    </div>

                    <button type="submit" class="btn btn-add form-submit tag-notch">Crear producto</button>
                </form>

                <% if (locals.errors_product) { %>
                    <ul class="error-list">
                        <% for (error of errors_product) { %>
                            <li><%= error.msg %></li>
                        <% } %>
                    </ul>
                <% } %>
            </div>
        </main>
    </div>

    <script>
        // purely visual: live-previews the photo URL as the user types, never touches form submission
        (function () {
            var input = document.getElementById("product_photo");
            var wrap = document.getElementById("photoPreview");
            var img = document.getElementById("photoPreviewImg");
            if (!input || !wrap || !img) return;

            input.addEventListener("input", function () {
                var url = input.value.trim();
                if (!url) {
                    wrap.classList.remove("has-image");
                    return;
                }
                img.src = url;
            });

            img.addEventListener("load", function () {
                wrap.classList.add("has-image");
            });

            img.addEventListener("error", function () {
                wrap.classList.remove("has-image");
            });
        })();
    </script>
</body>
</html>