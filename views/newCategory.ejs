<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel = "stylesheet" href = "/styles/general.css">
    <link rel = "stylesheet" href = "/styles/categoriesStyles.css">
    <link rel = "stylesheet" href = "/styles/newCategoryStyles.css">
    <title>Categorías | Mercadona</title>
    <link rel="icon" type="image/png" href="/images/mercadona.png">
</head>
<body>
    <div class="container">
        <%- include ("partials/navbar") %>
        <main class="homeNewCategory">
            <div class="form-card newCategory-card">
                <span class = "title">Nueva categoría</span>
                <p class="newCategory-subtitle">Dale un nombre claro, será el que vea todo el equipo.</p>

                <form method="POST" action="/categorias/nueva" class="newCategoryForm">
                    <div class="field">
                        <label for="category_name">Nombre</label>
                        <input id="category_name" name="category_name" placeholder="Frutas...">
                    </div>
                    <button type="submit" class="btn btn-add form-submit tag-notch">Crear categoría</button>
                </form>

                <% if (locals.errors) { %>
                    <% console.log(errors) %>
                    <ul class="error-list">
                        <% for (error of errors) { %>
                            <li><%= error.msg %></li>
                        <% } %>
                    </ul>
                <% } %>
            </div>
        </main>
    </div>
</body>
</html>