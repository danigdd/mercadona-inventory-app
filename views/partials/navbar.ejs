<link rel="stylesheet" href="/styles/navbarStyles.css">

<nav class="navbar">

    <a href="/" class="navbar-logo">
        <img class = "mobileLogo" src="/images/mercadona_logo_mobile.svg" alt = "logo">
        <img class = "desktopLogo" src="/images/mercadona_text_logo.svg" alt="logo">
    </a>

    <div class="navbar-links">
        <% navItems.forEach(item => { %>
            <a href="<%= item.path %>" class="navbar-content <%= isActive(item.path) ? 'active' : '' %>">
                <%= item.name %>
            </a>
        <% } ) %>
    </div>

</nav>