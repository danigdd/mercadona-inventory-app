<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel = "stylesheet" href = "/styles/general.css">
    <link rel = "stylesheet" href = "/styles/categoriesStyles.css">
    <title>Categorías | Mercadona</title>
    <link rel="icon" href="/images/favicon.svg" type="image/svg+xml">
</head>
<body>
    <div class="container">
        <%- include ("partials/navbar") %>
        <main class="homeCategories">
            <div class="panelOptions">
                <div>
                    <p class="panelOptions-eyebrow">Pasillo</p>
                    <h1 class="panelOptions-title">Categorías</h1>
                </div>
                <a href = "/categorias/nueva" class="btn btn-add tag-notch">
                    <svg class="btn-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
                        <path d="M12 5v14M5 12h14"/>
                    </svg>
                    Añadir categoría
                </a>
            </div>

            <% if (categories.length === 0) { %>
                <div class="empty-state">
                    <span class="empty-state-icon">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M3 8l9-4 9 4-9 4-9-4z"/>
                            <path d="M3 8v8l9 4 9-4V8"/>
                            <path d="M12 12v8"/>
                        </svg>
                    </span>
                    <p class="empty-state-title">Aún no hay categorías</p>
                    <p class="empty-state-desc">Crea la primera para empezar a organizar tu inventario.</p>
                </div>
            <% } else { %>
                <div class="containerCategories">
                    <% for (category of categories) { %>
                        <div class="category">
                            <a href="/categories/<%= category.name.toLowerCase() %>" class="category-link">
                                <span class="category-tag tag-notch">Nº <%= category.id %></span>
                                <span class="category-name"><%= category.name %></span>
                            </a>
                            <form method="GET" action="/categorias/<%= category.id %>/delete/" class="category-delete-form">
                                <button type = "submit" class="btn-icon-only" aria-label="Eliminar <%= category.name %>">
                                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                                        <path d="M4 7h16"/>
                                        <path d="M9 7V4h6v3"/>
                                        <path d="M6 7l1 13h10l1-13"/>
                                    </svg>
                                </button>
                            </form>
                        </div>
                    <% } %>
                </div>
            <% } %>
        </main>
    </div>
</body>
</html>